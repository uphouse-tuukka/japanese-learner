# Basic auth for app access (optional in development)
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Optional cookie/session signing secret; defaults to a derived secret from BASIC_AUTH_PASSWORD.
# Recommended for production/public deployments, especially if BASIC_AUTH_PASSWORD is unset or weak.
AUTH_SECRET=

# Turso database connection (required)
# Example: libsql://your-database-name.turso.io
TURSO_DATABASE_URL=
# Turso auth token with read/write access
TURSO_AUTH_TOKEN=

# OpenAI API key (required for TTS endpoint and optional AI utilities)
OPENAI_API_KEY=

# Toggle OpenAI-backed TTS from server-provided layout data (false = browser speech only)
USE_OPENAI_TTS=true

# Daily per-user token budget (used by token limiter)
DAILY_TOKEN_LIMIT=100000
# Monthly token budget is derived as DAILY_TOKEN_LIMIT * 31.
# Deprecated/unused: MONTHLY_TOKEN_BUDGET is not read by the app.
# Monthly estimated cost limit in USD (for monitoring/documentation)
MONTHLY_COST_LIMIT=20
# Local/dev override: unlock all travel missions regardless of progress
# MISSIONS_UNLOCK_ALL=true
# Local dev only: bypass portfolio/public challenge quota checks
# DISABLE_PORTFOLIO_QUOTA=true
# Optional bypass key for admin/internal testing
BYPASS_KEY=
# Maximum number of user profiles in app
MAX_USERS=5
# Enable/disable practice mode features
PRACTICE_MODE_ENABLED=true
# AI session generation timeout in milliseconds
SESSION_GENERATION_TIMEOUT_MS=30000
