{
  "name": "japanese-learner",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "svelte-kit sync || echo '' && husky || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "codegraph:preflight": "node scripts/codegraph-preflight.mjs",
    "codegraph:cli": "npm exec --yes --package @colbymchenry/codegraph@0.9.5 -- codegraph",
    "codegraph:init": "npm run codegraph:preflight && npm run codegraph:cli -- init -i .",
    "codegraph:sync": "npm run codegraph:preflight && npm run codegraph:cli -- sync .",
    "codegraph:status": "npm run codegraph:cli -- status .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run check && npm run lint && npm run test",
    "validate:ci": "npm run format:check && npm run check && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "openai": "^6.32.0"
  },
  "lint-staged": {
    "*.{js,ts,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "cookie": "0.7.2"
  }
}
